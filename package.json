{
  "name": "prompt-optimizer",
  "displayName": "prompt-optimizer",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.103.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
  "viewsContainers": {
    "activitybar": [
      {
        "id": "prompt-optimizer-sidebar",
        "title": "Prompt 优化",
        "icon": "media/wand.svg"
      }
    ]
  },
  "views": {
    "prompt-optimizer-sidebar": [
      {
        "id": "promptOptimizer.panel",
        "name": "优化面板",
        "type": "webview"
      }
    ]
  },
  "configuration": {
    "title": "Prompt Optimizer",
    "properties": {
      "promptOptimizer.apiEndpoint": {
        "type": "string",
        "default": "https://api.openai.com/v1/chat/completions",
        "description": "兼容 OpenAI 格式的 API 地址"
      },
      "promptOptimizer.apiKey": {
        "type": "string",
        "default": "",
        "description": "API Key（建议后续改用 vscode.secrets 加密存储）"
      },
      "promptOptimizer.model": {
        "type": "string",
        "default": "gpt-4o",
        "description": "使用的模型名称"
      }
    }
  }
},
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.103.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
  
}
