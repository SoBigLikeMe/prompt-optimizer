{
  "name": "prompt-plus",
  "displayName": "Prompt Plus",
  "description": "VS Code 提示词优化助手",
  "icon": "logo.jpg",
  "version": "0.0.3",
  "publisher": "fuchuanye",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SoBigLikeMe/prompt-optimizer.git"
  },
  "engines": {
    "vscode": "^1.103.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "prompt-plus-sidebar",
          "title": "Prompt Plus",
          "icon": "media/wand.svg"
        }
      ]
    },
    "views": {
      "prompt-plus-sidebar": [
        {
          "id": "promptPlus.panel",
          "name": "让大模型更懂你",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "Prompt Plus",
      "properties": {
        "promptPlus.apiEndpoint": {
          "type": "string",
          "default": "https://api.openai.com/v1/chat/completions",
          "description": "兼容 OpenAI 格式的 API 地址"
        },
        "promptPlus.apiKey": {
          "type": "string",
          "default": "",
          "description": "API Key（建议后续改用 vscode.secrets 加密存储）"
        },
        "promptPlus.model": {
          "type": "string",
          "default": "gpt-4o",
          "description": "使用的模型名称"
        },
        "promptPlus.temperature": {
          "type": "number",
          "default": 0.2,
          "minimum": 0,
          "maximum": 2,
          "description": "采样温度，范围 0~2"
        },
        "promptPlus.maxTokens": {
          "type": "number",
          "default": 1200,
          "minimum": 1,
          "description": "单次返回的最大 token 数"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.103.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
